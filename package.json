{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "c41-ch-backend",
    "description": "C41.ch Backend – React 19 + Inertia.js + TypeScript frontend",
    "private": true,
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/adrirubim/c41.ch-be.git"
    },
    "bugs": {
        "url": "https://github.com/adrirubim/c41.ch-be/issues"
    },
    "scripts": {
        "dev": "vite",
        "dev:frontend": "vite",
        "build": "vite build",
        "build:frontend": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "check:no-unsafe-html": "bash scripts/check-no-unsafe-html.sh",
        "check": "npm run format:check && npm run check:no-unsafe-html && npm run lint && npm run types && npm run build:frontend",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "types": "tsc --noEmit",
        "test": "php artisan test"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@eslint-react/dom": "^4.2.3",
        "@eslint-react/eslint-plugin": "^4.2.3",
        "@eslint-react/web-api": "^4.2.3",
        "@eslint/js": "^10.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@rolldown/plugin-babel": "^0.2.2",
        "@types/node": "^25.5.0",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.5"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.9",
        "@inertiajs/react": "^3.0.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tailwindcss/vite": "^4.2.2",
        "@tiptap/extension-image": "^3.21.0",
        "@tiptap/extension-link": "^3.21.0",
        "@tiptap/extension-table": "^3.21.0",
        "@tiptap/extension-table-cell": "^3.21.0",
        "@tiptap/extension-table-header": "^3.21.0",
        "@tiptap/extension-table-row": "^3.21.0",
        "@tiptap/react": "^3.21.0",
        "@tiptap/starter-kit": "^3.21.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "concurrently": "^9.2.1",
        "globals": "^17.4.0",
        "input-otp": "^1.4.2",
        "laravel-vite-plugin": "^3.0.0",
        "lucide-react": "^1.7.0",
        "react": "^19.2.4",
