# Copy this file to .env and fill in your values. Never commit .env or real credentials.

APP_NAME="C41.ch"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
# Local dev default (no external services required)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Postgres (production/CI-like local). Enable by switching DB_CONNECTION and setting credentials.
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=c41
# DB_USERNAME=postgres
# DB_PASSWORD=your_password_here

# Optional: passwords for seeders (development only; leave empty to use defaults)
# SEEDER_ADMIN_PASSWORD=
# SEEDER_TEST_PASSWORD=

# Demo dataset (development only)
# - SEED_DEMO_USERS_COUNT: number of demo users (in addition to admin/test)
# - SEED_DEMO_RESET: if true, PostSeeder clears ALL posts + pivot tables before re-generating demo posts
SEED_DEMO_USERS_COUNT=10
SEED_DEMO_RESET=false

# Demo post tone (development only)
# - SEED_POST_TONE: mixed|tecnico|ux|marketing
SEED_POST_TONE=tecnico

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Local default; set true in production (HTTPS required)
SESSION_SECURE_COOKIE=false

# Inertia SSR
# Enable only when the SSR server is running and reachable from PHP.
# INERTIA_SSR_ENABLED=true
# INERTIA_SSR_URL=http://127.0.0.1:13714

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Fortify rate limits (attempts per minute)
# Local (default template): generous values for development.
# In production (cdmon) override with e.g.:
#   FORTIFY_LOGIN_RATE_LIMIT_ATTEMPTS=3
#   FORTIFY_TWO_FACTOR_RATE_LIMIT_ATTEMPTS=3
FORTIFY_LOGIN_RATE_LIMIT_ATTEMPTS=100
FORTIFY_TWO_FACTOR_RATE_LIMIT_ATTEMPTS=20

# AI / Laravel AI SDK
# Global feature flag for AI-powered features. Keep false by default and enable
# explicitly per environment once providers and guardrails are configured.
AI_ENABLED=false
# Restrict editorial AI to admins while the feature is in rollout.
AI_EDITORIAL_ADMIN_ONLY=true
# Dedicated throttling for editorial AI endpoint (attempts per minute).
AI_EDITORIAL_RATE_LIMIT_ATTEMPTS=6
# Laravel AI provider runtime config (used by editorial suggestions service).
# Keep empty to use deterministic local fallback.
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
# Provider credentials (never commit real keys; set via secret manager)
OPENAI_API_KEY=

# Hybrid search (Postgres full-text + LIKE fallback)
# Keep disabled by default in local SQLite.
SEARCH_HYBRID_ENABLED=false
SEARCH_SEMANTIC_ENABLED=false
